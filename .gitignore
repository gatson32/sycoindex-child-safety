# ══════════════════════════════════════════
# SYCOINDEX — FILES THAT MUST NEVER BE COMMITTED
# ══════════════════════════════════════════

# ── API KEYS & SECRETS ──
.env
.env.*
*.env

# ── PROPRIETARY SCORING SYSTEM ──
scripts/
api/server.py
api/internal/

# ── PROPRIETARY METHODOLOGY & RUBRICS ──
*-RUBRIC-*.md
*-SPEC-*.md
*-DESIGN.md
*-PROTOCOL.md
*-CROSSWALK-*.md
RESEARCH-LOG.md
OPEN-METHODOLOGY-*.md

# ── RAW SCORED DATA & JUDGE OUTPUTS ──
# Everything in data/audit/ is private EXCEPT the public aggregate
# audit report (judge-bias.json), which powers judge-bias-audit.html.
data/audit/*
!data/audit/judge-bias.json
data/pai-pilot-scored*.json
data/pai-calibration-scored.json
data/pai-scored-*.json
data/score-history.jsonl
data/submissions.json
data/*.bak
data/*.partial*

# ── PROPRIETARY CORPUS & EVALUATION DATA ──
data/pai-corpus-*.json
data/pai-pilot-corpus.json
data/pai-calibration-corpus.json
data/pai-personas.json
data/pai-leaderboard.json

# ── SHELL SCRIPTS WITH KEYS ──
*.sh

# ── INTERNAL DOCUMENTS ──
reports/
reddit-posts/
content/
pilot-transcripts-*.json

# ── PREVIEW / INTERNAL IMAGES ──
preview-*.png
cert-*.png

# ── OLD VERSIONS ──
sycoindex-homepage-v2.html
sycoindex-homepage-v3.html
pai-leaderboard-dashboard.html
scorecard-preview.jsx

# ── PYTHON ──
*.py
*.pyc
__pycache__/

# ── GITHUB ACTION OUTPUT ──
sycoindex-report.json

# ── SYSTEM ──
.DS_Store
.vercel
node_modules/

# ── SCRATCH / BACKUP ARTIFACTS (never commit) ──
# Pre-run backups from scoring pipeline
data/*.pre-*
data/*.pre-*.json
# Smoke-test byproducts
data/*.smoke-failed-*
# Screenshots dropped into the repo root
Screenshot *.png
# LaTeX intermediates (keep .tex, .bib, .pdf only)
preprint/*.aux
preprint/*.bbl
preprint/*.blg
preprint/*.fdb_latexmk
preprint/*.fls
preprint/*.log
preprint/*.out
preprint/tmp*.tmp
# Compiled preprint PDF — Zenodo hosts the canonical copy (DOI 10.5281/zenodo.19656141)
preprint/sycoindex-v1.pdf
# Parked lock files from sandbox git hiccups
.git/*.stale*
.git/*stale_*
